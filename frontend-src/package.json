{
  "name": "eatopia-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@react-oauth/google": "^0.12.2",
    "axios": "^1.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.0",
    "react-scripts": "5.0.1",
    "react-toastify": "^11.0.5",
    "web-vitals": "^4.2.4"
  },
  "scripts": {
    "start": "node scripts/patch-react-scripts-wds5.js && react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --runInBand",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "postinstall": "node scripts/patch-react-scripts-wds5.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "nth-check": "2.1.1",
    "postcss": "8.5.13",
    "serialize-javascript": "7.0.5",
    "underscore": "1.13.8",
    "uuid": "14.0.0",
    "webpack-dev-server": "5.2.3"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2"
  }
}
